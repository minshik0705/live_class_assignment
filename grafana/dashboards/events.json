{
  "uid": "liveklass-events",
  "title": "이벤트 로그 대시보드",
  "description": "이벤트 파이프라인 분석 대시보드 — 모든 패널의 SQL은 analysis/queries.sql의 집계 쿼리와 대응한다",
  "tags": ["events", "pipeline"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "",
  "time": { "from": "now-7d", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "총 이벤트 수",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "eventdb-pg" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "eventdb-pg" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT count(*) AS \"총 이벤트\" FROM events WHERE $__timeFilter(event_time)"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "에러율",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "postgres", "uid": "eventdb-pg" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "eventdb-pg" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT round(100.0 * count(*) FILTER (WHERE event_type = 'error') / count(*), 2) AS \"에러율\" FROM events WHERE $__timeFilter(event_time)"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "신규 방문자 (첫 page_view)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "postgres", "uid": "eventdb-pg" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "eventdb-pg" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT count(*) AS \"신규 방문자\" FROM (SELECT user_id, min(event_time) AS first_seen FROM events WHERE event_type = 'page_view' GROUP BY user_id) t WHERE $__timeFilter(first_seen)"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "순 거래액 (결제 − 환불)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "postgres", "uid": "eventdb-pg" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "currencyKRW" },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "eventdb-pg" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COALESCE(sum(CASE WHEN event_type = 'purchase' THEN amount WHEN event_type = 'refund' THEN -amount END), 0) AS \"순 거래액\" FROM events WHERE $__timeFilter(event_time)"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "시간대별 이벤트 추이 (타입별, 1시간 단위)",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "postgres", "uid": "eventdb-pg" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "eventdb-pg" },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT $__timeGroup(event_time, '1h') AS time, event_type AS metric, count(*) AS value FROM events WHERE $__timeFilter(event_time) GROUP BY 1, 2 ORDER BY 1"
        }
      ]
    },
    {
      "id": 6,
      "type": "barchart",
      "title": "일별 거래액 — 결제 vs 환불",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "postgres", "uid": "eventdb-pg" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "currencyKRW" },
        "overrides": []
      },
      "options": {
        "orientation": "auto",
        "xTickLabelRotation": 0,
        "showValue": "auto",
        "stacking": "none",
        "groupWidth": 0.7,
        "barWidth": 0.85,
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "eventdb-pg" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT to_char(date_trunc('day', event_time), 'MM-DD') AS \"일자\", COALESCE(sum(amount) FILTER (WHERE event_type = 'purchase'), 0) AS \"결제액\", COALESCE(sum(amount) FILTER (WHERE event_type = 'refund'), 0) AS \"환불액\" FROM events WHERE $__timeFilter(event_time) GROUP BY date_trunc('day', event_time) ORDER BY date_trunc('day', event_time)"
        }
      ]
    },
    {
      "id": 7,
      "type": "piechart",
      "title": "이벤트 타입별 건수",
      "gridPos": { "h": 9, "w": 6, "x": 12, "y": 13 },
      "datasource": { "type": "postgres", "uid": "eventdb-pg" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": true, "calcs": [], "fields": "" },
        "pieType": "donut",
        "displayLabels": ["name", "percent"],
        "legend": { "displayMode": "list", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "eventdb-pg" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT event_type, count(*) AS \"건수\" FROM events WHERE $__timeFilter(event_time) GROUP BY event_type ORDER BY 2 DESC"
        }
      ]
    },
    {
      "id": 8,
      "type": "table",
      "title": "활동 상위 10 유저 (헤비유저 skew 확인)",
      "gridPos": { "h": 9, "w": 6, "x": 18, "y": 13 },
      "datasource": { "type": "postgres", "uid": "eventdb-pg" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "short" },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "footer": { "show": false, "reducer": ["sum"], "countRows": false, "fields": "" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "eventdb-pg" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT user_id AS \"유저\", count(*) AS \"이벤트 수\" FROM events WHERE $__timeFilter(event_time) GROUP BY user_id ORDER BY 2 DESC LIMIT 10"
        }
      ]
    }
  ]
}
